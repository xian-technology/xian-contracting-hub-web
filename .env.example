# Local runtime settings for contracting-hub.
CONTRACTING_HUB_ENV=development
CONTRACTING_HUB_INSTANCE_DIR=.local
CONTRACTING_HUB_DB_PATH=.local/contracting_hub.db

# If you need a non-default SQLAlchemy URL, this takes precedence over CONTRACTING_HUB_DB_PATH.
# CONTRACTING_HUB_DB_URL=sqlite:////absolute/path/to/contracting_hub.db
# REFLEX_DB_URL=sqlite:////absolute/path/to/contracting_hub.db
