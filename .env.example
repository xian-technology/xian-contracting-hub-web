# Local runtime settings for contracting-hub.
CONTRACTING_HUB_ENV=development
CONTRACTING_HUB_INSTANCE_DIR=.local
CONTRACTING_HUB_DB_PATH=.local/contracting_hub.db

# If you need a non-default SQLAlchemy URL, this takes precedence over CONTRACTING_HUB_DB_PATH.
# CONTRACTING_HUB_DB_URL=sqlite:////absolute/path/to/contracting_hub.db
# REFLEX_DB_URL=sqlite:////absolute/path/to/contracting_hub.db

# Optional local bootstrap seed overrides for `python -m contracting_hub.services.bootstrap`.
# Leave email or username blank to skip creating the bootstrap admin account.
# CONTRACTING_HUB_BOOTSTRAP_ADMIN_EMAIL=admin@contractinghub.local
# CONTRACTING_HUB_BOOTSTRAP_ADMIN_USERNAME=admin
# CONTRACTING_HUB_BOOTSTRAP_ADMIN_DISPLAY_NAME=Local Admin
# CONTRACTING_HUB_BOOTSTRAP_ADMIN_PASSWORD_HASH=!bootstrap-admin-auth-pending!
